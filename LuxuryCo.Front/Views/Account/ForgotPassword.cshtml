@model LuxuryCo.Front.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Recuperar Contraseña";
}

<div class="auth-page-bg">
    <div class="auth-card">
        <div class="text-center mb-4">
            <div class="auth-brand-title">LUXURYCO</div>
            <div class="auth-brand-sub">Recupera tu acceso</div>
        </div>

        <p class="mb-4" style="font-size:.87rem;color:#aaa;text-align:center;">
            Ingresa el correo de tu cuenta y te enviaremos un enlace para restablecer tu contraseña.
        </p>

        <form asp-action="ForgotPassword" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="auth-alert-error"></div>

            <div class="mb-4">
                <label class="auth-label">Correo Electrónico</label>
                <input asp-for="Email" class="auth-input" placeholder="tu@correo.com" />
                <span asp-validation-for="Email" class="text-danger" style="font-size:.78rem;"></span>
            </div>

            <button type="submit" class="btn-auth-primary mb-3">
                <i class="fas fa-paper-plane me-2"></i> Enviar Enlace
            </button>

            <hr class="auth-divider" />
            <p class="text-center mb-0" style="font-size:.83rem;">
                <a asp-action="Login" asp-controller="Account" class="auth-link">← Volver al inicio de sesión</a>
            </p>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
