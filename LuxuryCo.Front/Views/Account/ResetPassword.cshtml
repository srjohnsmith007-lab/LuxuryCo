@model LuxuryCo.Front.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Nueva Contraseña";
}

<div class="auth-page-bg">
    <div class="auth-card">

        <div id="loading-container" class="text-center py-4">
            <div class="auth-brand-title mb-2">LUXURYCO</div>
            <div class="auth-brand-sub">Verificando enlace seguro...</div>
            <div class="mt-4" style="color:#aaa;font-size:.85rem;">
                <i class="fas fa-shield-alt me-2" style="color:#d4af37;"></i>
                Validando tu acceso confidencial, por favor espera.
            </div>
        </div>

        <div id="error-container" style="display:none;" class="text-center py-4">
            <div style="font-size:3rem;color:#ef5350;margin-bottom:1rem;"><i class="fas fa-lock"></i></div>
            <div class="auth-brand-title mb-2">Enlace Inválido</div>
            <p style="color:#aaa;font-size:.87rem;margin:1.5rem 0;">
                No se detectó un token de seguridad válido. Asegúrate de haber hecho clic en el enlace completo de tu correo.
            </p>
            <a asp-action="Login" asp-controller="Account" class="btn-auth-primary" style="text-decoration:none;display:block;">
                Volver al Inicio de Sesión
            </a>
        </div>

        <div id="form-container" style="display:none;">
            <div class="text-center mb-4">
                <div style="font-size:2.5rem;color:#d4af37;margin-bottom:.75rem;"><i class="fas fa-key"></i></div>
                <div class="auth-brand-title">Nueva Contraseña</div>
                <div class="auth-brand-sub">Elige una contraseña segura</div>
            </div>

            <form method="post" asp-action="ResetPassword" asp-controller="Account">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="auth-alert-error" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                <input type="hidden" id="AccessToken"  name="AccessToken"  value="@Model?.AccessToken" />
                <input type="hidden" id="RefreshToken" name="RefreshToken" value="@Model?.RefreshToken" />

                <div class="mb-4">
                    <label class="auth-label">Nueva Contraseña</label>
                    <input name="NewPassword" type="password" class="auth-input" placeholder="Mínimo 6 caracteres" required minlength="6" />
                </div>
                <div class="mb-5">
                    <label class="auth-label">Confirmar Contraseña</label>
                    <input name="ConfirmPassword" type="password" class="auth-input" placeholder="Repite la contraseña" required minlength="6" />
                </div>

                <button type="submit" class="btn-auth-primary">
                    <i class="fas fa-save me-2"></i> Guardar Contraseña
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
    const hash = window.location.hash.substring(1);
    const params = new URLSearchParams(hash);
    const accessToken = params.get('access_token');
    const refreshToken = params.get('refresh_token');

    if (accessToken && refreshToken) {
        document.getElementById('AccessToken').value = accessToken;
        document.getElementById('RefreshToken').value = refreshToken;
        document.getElementById('loading-container').style.display = 'none';
        document.getElementById('form-container').style.display = 'block';
        if (window.history.replaceState) window.history.replaceState(null, null, window.location.pathname);
    } else {
        var modelToken = document.getElementById('AccessToken').value;
        document.getElementById('loading-container').style.display = 'none';
        document.getElementById(modelToken && modelToken.length > 10 ? 'form-container' : 'error-container').style.display = 'block';
    }
});
</script>
}
