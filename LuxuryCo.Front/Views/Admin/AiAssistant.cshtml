@{
    ViewData["Title"] = "Asistente Financiero IA";
}

<div class="container-fluid py-5" style="background-color: #000; min-height: 100vh; color: #fff;">
    <div class="d-flex justify-content-between align-items-center px-4 pt-3">
        <div>
            <h1 class="display-5 fw-bold" style="font-family: 'Playfair Display', serif; letter-spacing: 2px;">
                <i class="fas fa-brain me-2" style="color: var(--color-gold);"></i>ASISTENTE IA
            </h1>
            <p class="text-secondary">Tu asistente financiero personal de LuxuryCo.</p>
        </div>
    </div>

    <!-- Pestañas de Navegación Admin -->
    <partial name="_AdminNav" />

    <div class="row px-4 mt-4">
        <!-- Main Chat Area -->
        <div class="col-lg-9">
            <div class="card bg-black border-secondary rounded-0 shadow-lg" id="chat-container-card">
                <div class="card-header border-secondary bg-dark text-white d-flex justify-content-between align-items-center">
                    <span class="fw-bold"><i class="fas fa-robot me-2" style="color: var(--color-gold);"></i>LuxuryCo Admin AI</span>
                    <button class="btn btn-sm btn-outline-light" onclick="clearChat()">Limpiar Chat</button>
                </div>
                <div class="card-body p-4" id="chat-box" style="height: 500px; overflow-y: auto; background-color: var(--chat-bg, #0d0d0d);">
                    <div class="text-center text-secondary mb-4">
                        <small>El asistente está conectado a tu base de datos en tiempo real.</small>
                    </div>
                    <!-- Messages will appear here -->
                    <div id="messages-container"></div>
                    
                    <!-- Loading indicator -->
                    <div id="ai-typing" class="d-none mt-3">
                        <span class="badge" style="background-color: var(--color-gold); color: black;">
                            <i class="fas fa-circle-notch fa-spin me-1"></i>Analizando datos...
                        </span>
                    </div>
                </div>
                <div class="card-footer border-secondary" style="background-color: var(--chat-bg, #0d0d0d);">
                    <form id="chat-form" class="d-flex gap-2">
                        <input type="text" id="user-input" class="form-control rounded-0 border-secondary bg-dark text-white" placeholder="Pregunta sobre ventas, inventario, sugerencias..." autocomplete="off" required>
                        <button type="submit" class="btn btn-gold rounded-0 px-4 fw-bold">ENVIAR</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Customization Panel -->
        <div class="col-lg-3 mt-4 mt-lg-0">
            <div class="card bg-dark border-secondary rounded-0">
                <div class="card-header border-secondary bg-black">
                    <span class="fw-bold text-white"><i class="fas fa-paint-brush me-2"></i>Personalización Visual</span>
                </div>
                <div class="card-body">
                    <p class="small text-secondary mb-3">Cambia la apariencia del chat. Estos ajustes se guardan solo para ti en este navegador.</p>
                    
                    <div class="mb-3">
                        <label class="form-label text-white small">Fondo del Chat</label>
                        <select id="theme-selector" class="form-select form-select-sm bg-black text-white border-secondary rounded-0">
                            <option value="#0d0d0d">Luxury Dark (Por defecto)</option>
                            <option value="#1a1a2e">Deep Navy (Azul Oscuro)</option>
                            <option value="#2d2a26">Charcoal (Gris Mate)</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-white small">Color de tus Mensajes</label>
                        <input type="color" id="user-msg-color" class="form-control form-control-color bg-black border-secondary w-100" value="#333333" title="Elige un color">
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .chat-msg {
        max-width: 80%;
        margin-bottom: 15px;
        padding: 12px 18px;
        border-radius: 4px;
        line-height: 1.5;
        font-size: 0.95rem;
    }
    .msg-user {
        margin-left: auto;
        background-color: var(--user-msg-bg, #333);
        color: white;
        border-bottom-right-radius: 0;
    }
    .msg-ai {
        margin-right: auto;
        background-color: #1a1a1a;
        color: #e0e0e0;
        border: 1px solid #333;
        border-left: 3px solid var(--color-gold);
        border-bottom-left-radius: 0;
    }
    /* Scrollbar for chat */
    #chat-box::-webkit-scrollbar { width: 6px; }
    #chat-box::-webkit-scrollbar-track { background: transparent; }
    #chat-box::-webkit-scrollbar-thumb { background-color: #444; border-radius: 10px; }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        loadPreferences();

        const chatForm = document.getElementById('chat-form');
        const userInput = document.getElementById('user-input');
        const messagesContainer = document.getElementById('messages-container');
        const aiTyping = document.getElementById('ai-typing');
        const chatBox = document.getElementById('chat-box');

        // Customization Listeners
        document.getElementById('theme-selector').addEventListener('change', (e) => {
            document.documentElement.style.setProperty('--chat-bg', e.target.value);
            localStorage.setItem('ai_chat_bg', e.target.value);
        });

        document.getElementById('user-msg-color').addEventListener('change', (e) => {
            document.documentElement.style.setProperty('--user-msg-bg', e.target.value);
            localStorage.setItem('ai_user_color', e.target.value);
        });

        chatForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const text = userInput.value.trim();
            if (!text) return;

            appendMessage(text, 'user');
            userInput.value = '';
            
            aiTyping.classList.remove('d-none');
            chatBox.scrollTop = chatBox.scrollHeight;

            try {
                const response = await fetch('/Admin/SendAiMessage', {
                    method: 'POST',
                    credentials: 'include',  // Asegura que las cookies de sesión se envíen
                    headers: { 
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ message: text })
                });

                let data;
                const rawText = await response.text(); // Primero leer como texto
                try {
                    data = JSON.parse(rawText); // Luego intentar parsear como JSON
                } catch {
                    appendMessage("⚠️ Error de formato: La IA no respondió en formato correcto. ¿Está el Backend corriendo?", 'ai');
                    return;
                }
                
                if (response.ok) {
                    appendMessage(data.reply, 'ai');
                } else {
                    let errorMsg = "⚠️ Error: " + (data.message || "Error interno.");
                    if (data.details) errorMsg += "<br><small class='text-danger'>" + data.details + "</small>";
                    appendMessage(errorMsg, 'ai');
                }
            } catch (error) {
                appendMessage("⚠️ Error de conexión: " + error.message, 'ai');
            } finally {
                aiTyping.classList.add('d-none');
                chatBox.scrollTop = chatBox.scrollHeight;
            }
        });
    });

    function appendMessage(text, sender) {
        const div = document.createElement('div');
        div.className = `chat-msg msg-${sender}`;
        
        // Basic Markdown support (bold text)
        let formattedText = text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
        formattedText = formattedText.replace(/\n/g, '<br>');
        
        div.innerHTML = formattedText;
        document.getElementById('messages-container').appendChild(div);
    }

    function clearChat() {
        document.getElementById('messages-container').innerHTML = '';
    }

    function loadPreferences() {
        const savedBg = localStorage.getItem('ai_chat_bg');
        const savedUserColor = localStorage.getItem('ai_user_color');
        
        if (savedBg) {
            document.documentElement.style.setProperty('--chat-bg', savedBg);
            document.getElementById('theme-selector').value = savedBg;
        }
        if (savedUserColor) {
            document.documentElement.style.setProperty('--user-msg-bg', savedUserColor);
            document.getElementById('user-msg-color').value = savedUserColor;
        }
    }
</script>
