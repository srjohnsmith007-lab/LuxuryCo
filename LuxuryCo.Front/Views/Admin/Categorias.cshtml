@{
    ViewData["Title"] = "Categorías";
}

<div class="container-fluid py-4 px-4" style="min-height: 80vh; background-color: #0a0a0a; color: #fff;">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert mb-4" style="background-color: #0d2b1a; border: 1px solid #1a5e38; color: #5edb97; border-radius: 0;">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert mb-4" style="background-color: #2b0d0d; border: 1px solid #7d2e2e; color: #e57373; border-radius: 0;">
            <i class="fas fa-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
        </div>
    }

    <div class="row">
        <!-- Lista de Categorías -->
        <div class="col-lg-8 mb-4">
            <div style="border: 1px solid #1a1a1a;">
                <div class="d-flex align-items-center justify-content-between px-4 py-3" style="border-bottom: 1px solid #1a1a1a;">
                    <h5 class="mb-0 fw-bold" style="letter-spacing: 2px; font-size: 0.85rem; text-transform: uppercase;">Categorías del Catálogo</h5>
                    <span class="badge" style="background-color: #1a1a1a; color: #888; font-size: 0.75rem;">@(ViewBag.Categorias?.Count ?? 0) categorías</span>
                </div>
                <table class="table table-dark mb-0" style="font-size: 0.9rem; border-color: #1a1a1a;">
                    <thead style="background-color: #111; color: #888; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px;">
                        <tr>
                            <th class="px-4 py-3" style="border-color: #1a1a1a;">#</th>
                            <th class="py-3" style="border-color: #1a1a1a;">Nombre</th>
                            <th class="py-3" style="border-color: #1a1a1a;">Descripción</th>
                            <th class="py-3 text-end pe-4" style="border-color: #1a1a1a;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.Categorias != null)
                        {
                            foreach (var cat in ViewBag.Categorias as List<LuxuryCo.Front.ViewModels.CategoriaViewModel> ?? new())
                            {
                                <tr style="border-color: #1a1a1a;">
                                    <td class="px-4 py-3 text-secondary" style="border-color: #1a1a1a; font-size: 0.8rem;">@cat.id_categoria</td>
                                    <td class="py-3 fw-bold" style="border-color: #1a1a1a;">
                                        @if (cat.nombre == "Hombre" || cat.nombre == "Mujer" || cat.nombre == "Accesorios")
                                        {
                                            <span class="me-2" style="color: var(--color-gold, #d4af37);">●</span>
                                        }
                                        @cat.nombre
                                    </td>
                                    <td class="py-3 text-secondary" style="border-color: #1a1a1a; font-size: 0.85rem;">@(cat.descripcion ?? "—")</td>
                                    <td class="py-3 text-end pe-4" style="border-color: #1a1a1a;">
                                        <form asp-action="EliminarCategoria" asp-route-id="@cat.id_categoria" method="post"
                                              onsubmit="return confirm('¿Eliminar la categoría «@cat.nombre»? Solo es posible si no tiene productos asignados.')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm" style="background: none; border: 1px solid #333; color: #888; font-size: 0.75rem; padding: 4px 12px; border-radius: 0;">
                                                <i class="fas fa-trash-alt me-1"></i> Eliminar
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-secondary">No hay categorías registradas.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Formulario Nueva Categoría -->
        <div class="col-lg-4">
            <div style="border: 1px solid #1a1a1a;">
                <div class="px-4 py-3" style="border-bottom: 1px solid #1a1a1a;">
                    <h5 class="mb-0 fw-bold" style="letter-spacing: 2px; font-size: 0.85rem; text-transform: uppercase;">Nueva Categoría</h5>
                </div>
                <div class="p-4">
                    <form asp-action="CrearCategoria" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label small fw-bold" style="color: #888; letter-spacing: 1px; text-transform: uppercase; font-size: 0.75rem;">Nombre *</label>
                            <input name="Nombre" type="text" class="form-control cat-input" placeholder="Ej: Hombre, Mujer, Accesorios" required />
                        </div>
                        <div class="mb-4">
                            <label class="form-label small fw-bold" style="color: #888; letter-spacing: 1px; text-transform: uppercase; font-size: 0.75rem;">Descripción (opcional)</label>
                            <textarea name="Descripcion" class="form-control cat-input" rows="3" placeholder="Ropa para hombre..."></textarea>
                        </div>
                        <button type="submit" class="btn w-100 py-3 fw-bold" style="background-color: #fff; color: #000; border-radius: 0; letter-spacing: 2px; font-size: 0.85rem;">
                            <i class="fas fa-plus me-2"></i> AGREGAR CATEGORÍA
                        </button>
                    </form>

                    <hr style="border-color: #222; margin: 1.5rem 0;">

                    <div>
                        <p class="small mb-3" style="color: #666; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px;">Categorías Estándar</p>
                        <div class="d-flex flex-wrap gap-2">
                            <button onclick="fillName('Hombre')" class="btn btn-sm cat-quick" type="button">Hombre</button>
                            <button onclick="fillName('Mujer')" class="btn btn-sm cat-quick" type="button">Mujer</button>
                            <button onclick="fillName('Accesorios')" class="btn btn-sm cat-quick" type="button">Accesorios</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Nota -->
            <div class="mt-3 p-3" style="background-color: #0d1a0d; border: 1px solid #1a3a1a; font-size: 0.8rem; color: #5a8a5a;">
                <i class="fas fa-info-circle me-2"></i>
                Las categorías con <span style="color: #d4af37;">●</span> aparecen en la tienda pública bajo su sección correspondiente.
            </div>
        </div>
    </div>
</div>

<style>
    .cat-input {
        background-color: #1a1a1a !important;
        border: 1px solid #333 !important;
        color: #fff !important;
        border-radius: 0 !important;
        padding: 12px 15px !important;
    }
    .cat-input:focus {
        border-color: #555 !important;
        box-shadow: none !important;
        background-color: #222 !important;
    }
    .cat-input::placeholder { color: #555 !important; }
    .cat-quick {
        background-color: #1a1a1a;
        border: 1px solid #333;
        color: #aaa;
        border-radius: 0;
        font-size: 0.75rem;
        letter-spacing: 1px;
        text-transform: uppercase;
    }
    .cat-quick:hover {
        background-color: #d4af37;
        border-color: #d4af37;
        color: #000;
    }
</style>

<script>
    function fillName(name) {
        document.querySelector('input[name="Nombre"]').value = name;
    }
</script>
