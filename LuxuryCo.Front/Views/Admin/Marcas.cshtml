@model List<LuxuryCo.Front.ViewModels.MarcaViewModel>
@{
    ViewData["Title"] = "Gestión de Marcas";
}

<style>
    .admin-container { max-width: 1100px; margin: 3rem auto; padding: 0 20px; }
    .admin-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; border-bottom: 2px solid #111; padding-bottom: 1rem; }
    .admin-title { font-size: 1.4rem; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; }
    .btn-dark-admin { background: #111; color: #fff; padding: 10px 22px; font-weight: 700; font-size: 0.8rem; letter-spacing: 1px; text-transform: uppercase; text-decoration: none; border: none; cursor: pointer; transition: background .2s; display: inline-block; }
    .btn-dark-admin:hover { background: #000; color: #fff; }
    .btn-light-admin { background: transparent; color: #111; padding: 8px 16px; font-weight: 600; font-size: 0.8rem; letter-spacing: 1px; text-transform: uppercase; text-decoration: none; border: 1px solid #111; cursor: pointer; transition: all .2s; display: inline-block; }
    .btn-light-admin:hover { background: #111; color: #fff; }
    .btn-danger-admin { background: transparent; color: #c00; padding: 8px 16px; font-weight: 600; font-size: 0.8rem; letter-spacing: 1px; text-transform: uppercase; border: 1px solid #c00; cursor: pointer; transition: all .2s; }
    .btn-danger-admin:hover { background: #c00; color: #fff; }
    .admin-table { width: 100%; border-collapse: collapse; margin-top: 1rem; }
    .admin-table th { font-size: 0.75rem; letter-spacing: 2px; text-transform: uppercase; color: #888; border-bottom: 1px solid #eee; padding: 10px 12px; text-align: left; }
    .admin-table td { padding: 16px 12px; border-bottom: 1px solid #f5f5f5; vertical-align: middle; font-size: 0.9rem; }
    .admin-table tr:hover td { background: #fafafa; }
    .logo-thumb { width: 50px; height: 50px; object-fit: contain; border: 1px solid #eee; padding: 4px; background: #fff; }
    .no-logo { width: 50px; height: 50px; background: #f0f0f0; display: flex; align-items: center; justify-content: center; font-size: 0.65rem; color: #aaa; letter-spacing: 1px; }
    .alert-success { background: #f0fff4; border-left: 3px solid #38a169; color: #276749; padding: 12px 16px; margin-bottom: 1.5rem; font-size: 0.9rem; }
    .alert-error { background: #fff5f5; border-left: 3px solid #c53030; color: #742a2a; padding: 12px 16px; margin-bottom: 1.5rem; font-size: 0.9rem; }
    .back-link { font-size: 0.8rem; letter-spacing: 1px; text-transform: uppercase; color: #555; text-decoration: none; display: inline-block; margin-bottom: 2rem; }
    .back-link:hover { color: #111; }
    .actions-col { display: flex; gap: 8px; }
</style>

<div class="admin-container">
    <a href="/Admin" class="back-link">← Panel de Control</a>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert-error">@TempData["ErrorMessage"]</div>
    }

    <div class="d-flex justify-content-between align-items-center px-4 pt-3">
        <div>
            <h1 class="display-5 fw-bold" style="font-family: 'Playfair Display', serif; letter-spacing: 2px;">MARCAS</h1>
            <p class="text-secondary">Administra los proveedores y diseñadores exclusivos.</p>
        </div>
        <a asp-action="CrearMarca" class="btn btn-outline-light px-4 py-2" style="border-radius: 0; letter-spacing: 1px; font-weight: 500;">
            <i class="fas fa-plus me-2"></i> NUEVA MARCA
        </a>
    </div>

    <!-- Pestañas de Navegación Admin -->
    <partial name="_AdminNav" />


    @if (Model == null || !Model.Any())
    {
        <p style="color: #888; font-size: 0.9rem;">Aún no tienes marcas registradas. ¡Crea la primera!</p>
    }
    else
    {
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Logo</th>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var marca in Model)
                {
                    <tr id="marca-@marca.IdMarca">
                        <td>
                            @if (!string.IsNullOrEmpty(marca.LogoUrl))
                            {
                                <img src="@marca.LogoUrl" class="logo-thumb" alt="@marca.Nombre" />
                            }
                            else
                            {
                                <div class="no-logo">SIN LOGO</div>
                            }
                        </td>
                        <td><strong>@marca.Nombre</strong></td>
                        <td style="max-width: 300px; color: #555;">@(marca.Descripcion?.Length > 80 ? marca.Descripcion.Substring(0, 80) + "..." : marca.Descripcion)</td>
                        <td>
                            <div class="actions-col">
                                <a asp-action="EditarMarca" asp-controller="Admin" asp-route-id="@marca.IdMarca" class="btn-light-admin">Editar</a>
                                <form method="post" asp-action="EliminarMarca" asp-controller="Admin" style="display:inline;" onsubmit="return confirm('¿Eliminar esta marca?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@marca.IdMarca" />
                                    <button type="submit" class="btn-danger-admin">Eliminar</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
