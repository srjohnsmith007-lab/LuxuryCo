@using LuxuryCo.Front.ViewModels
@model List<ProductoViewModel>
@{
    ViewData["Title"] = "Panel de Administración";
}

<div class="container-fluid py-5" style="background-color: #000; min-height: 100vh; color: #fff;">
    <div class="d-flex justify-content-between align-items-center px-4 pt-3">
        <div>
            <h1 class="display-5 fw-bold" style="font-family: 'Playfair Display', serif; letter-spacing: 2px;">PRODUCTOS</h1>
            <p class="text-secondary">Gestión de inventario y catálogo exclusivo.</p>
        </div>
        <a asp-action="Create" class="btn btn-outline-light px-4 py-2" style="border-radius: 0; letter-spacing: 1px; font-weight: 500;">
            <i class="fas fa-plus me-2"></i> NUEVO PRODUCTO
        </a>
    </div>

    <!-- Pestañas de Navegación Admin -->
    <partial name="_AdminNav" />


    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mx-4" role="alert" style="border-radius: 0; background-color: #1a3a1a; color: #fff; border: 1px solid #2e7d32;">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card mx-4" style="background-color: #111; border: 1px solid #222; border-radius: 0;">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0" style="vertical-align: middle;">
                <thead style="background-color: #1a1a1a;">
                    <tr>
                        <th class="ps-4 py-3" style="width: 80px;">ID</th>
                        <th class="py-3">PRODUCTO</th>
                        <th class="py-3">CATEGORÍA</th>
                        <th class="py-3">MARCA</th>
                        <th class="py-3 text-end">PRECIO</th>
                        <th class="py-3 text-center">STOCK</th>
                        <th class="py-3 text-center">ESTADO</th>
                        <th class="pe-4 py-3 text-end">ACCIONES</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        @foreach (var p in Model)
                        {
                            <tr id="item-@p.IdProducto">
                                <td class="ps-4 text-secondary">#@p.IdProducto</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-secondary rounded-1 me-3" style="width: 45px; height: 45px; overflow: hidden; background: #222 url('@(p.ImagenPrincipalUrl ?? "https://via.placeholder.com/100")') center/cover no-repeat;"></div>
                                        <div>
                                            <div class="fw-bold">@p.Nombre</div>
                                            <div class="small text-secondary">@p.Referencia</div>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="badge bg-dark border border-secondary text-secondary fw-normal px-2 py-1">@p.CategoriaNombre</span></td>
                                <td>@p.MarcaNombre</td>
                                <td class="text-end fw-bold">$@(string.Format("{0:N0}", p.Precio))</td>
                                <td class="text-center">@p.Stock</td>
                                <td class="text-center">
                                    @if (p.Activo)
                                    {
                                        <span class="text-success"><i class="fas fa-check-circle me-1"></i> Activo</span>
                                    }
                                    else
                                    {
                                        <span class="text-secondary"><i class="fas fa-times-circle me-1"></i> Inactivo</span>
                                    }
                                </td>
                                <td class="pe-4 text-end">
                                    <div class="btn-group">
                                        <form asp-action="ToggleStatus" asp-route-id="@p.IdProducto" method="post" class="d-inline m-0 p-0">
                                            <button type="submit" class="btn btn-sm @(p.Activo ? "btn-outline-warning" : "btn-outline-success")" style="border-radius: 0;" title="@(p.Activo ? "Desactivar" : "Activar")">
                                                <i class="@(p.Activo ? "fas fa-eye-slash" : "fas fa-eye")"></i>
                                            </button>
                                        </form>
                                        <a asp-action="Edit" asp-route-id="@p.IdProducto" class="btn btn-sm btn-outline-light" style="border-radius: 0;"><i class="fas fa-edit"></i></a>
                                        <button type="button" class="btn btn-sm btn-outline-danger" style="border-radius: 0;" onclick="confirmDelete(@p.IdProducto, '@p.Nombre')">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-secondary italic">
                                No hay productos en el catálogo. Comienza agregando uno nuevo.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal confirmación borrado -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0" style="background-color: #111; color: #fff; border-radius: 0;">
            <div class="modal-header border-secondary">
                <h5 class="modal-title fw-bold" style="font-family: 'Playfair Display', serif;">Confirmar Eliminación</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                ¿Estás seguro de que deseas eliminar permanentemente el producto <strong id="deleteProdName"></strong>? <br>
                <strong>Nota:</strong> Esta acción no se puede deshacer. (Si deseas conservar el historial pero ocultarlo de la tienda, utiliza el botón del "Ojo" para desactivarlo y mantenerlo registrado).
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="border-radius: 0;">Cancelar</button>
                <form asp-action="Delete" method="post" id="deleteForm">
                    <input type="hidden" name="id" id="deleteId" />
                    <button type="submit" class="btn btn-danger" style="border-radius: 0;">Eliminar Permanentemente</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function confirmDelete(id, name) {
        document.getElementById('deleteProdName').innerText = name;
        document.getElementById('deleteId').value = id;
        new bootstrap.Modal(document.getElementById('deleteModal')).show();
    }
</script>
