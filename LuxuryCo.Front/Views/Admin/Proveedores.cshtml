@model List<LuxuryCo.Front.ViewModels.ProveedorViewModel>
@{
    ViewData["Title"] = "Proveedores - LuxuryCo Admin";
}

<div class="container-fluid py-5" style="background-color: #000; min-height: 100vh; color: #fff;">
    <div class="d-flex justify-content-between align-items-center px-4 pt-3">
        <div>
            <h1 class="display-5 fw-bold" style="font-family: 'Playfair Display', serif; letter-spacing: 2px;">PROVEEDORES</h1>
            <p class="text-secondary">Directorio de proveedores y mayoristas del sistema.</p>
        </div>
        <div class="text-end">
            <span class="badge border border-secondary text-secondary px-3 py-2" style="background-color: #111; font-weight: normal; letter-spacing: 1px;">
                <i class="fas fa-truck me-2"></i> @(Model?.Count ?? 0) REGISTRADOS
            </span>
            <a asp-action="CrearProveedor" asp-controller="Admin" class="btn btn-outline-light ms-3 px-4 py-2" style="border-radius: 0; letter-spacing: 1px; font-weight: 500; font-size: 0.85rem;">
                <i class="fas fa-plus me-2"></i> NUEVO PROVEEDOR
            </a>
        </div>
    </div>

    <partial name="_AdminNav" />

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mx-4" role="alert" style="border-radius: 0; background-color: #1a3a1a; color: #fff; border: 1px solid #2e7d32;">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mx-4" role="alert" style="border-radius: 0; background-color: #3d1a1a; color: #fff; border: 1px solid #7d2e2e;">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card mx-4" style="background-color: #111; border: 1px solid #222; border-radius: 0;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0" style="vertical-align: middle;">
                    <thead style="background-color: #1a1a1a;">
                        <tr>
                            <th class="ps-4 py-3" style="width: 70px;">ID</th>
                            <th class="py-3">NOMBRE</th>
                            <th class="py-3">CONTACTO</th>
                            <th class="py-3">TELÉFONO</th>
                            <th class="py-3">EMAIL</th>
                            <th class="py-3 text-center">ESTADO</th>
                            <th class="pe-4 py-3 text-end">ACCIONES</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Count > 0)
                        {
                            @foreach (var p in Model)
                            {
                                <tr>
                                    <td class="ps-4 text-secondary">#@p.IdProveedor</td>
                                    <td class="fw-bold">@p.Nombre</td>
                                    <td class="text-secondary">@(p.Contacto ?? "-")</td>
                                    <td class="text-secondary">@(p.Telefono ?? "-")</td>
                                    <td class="text-secondary">@(p.Email ?? "-")</td>
                                    <td class="text-center">
                                        <span class="@(p.Activo ? "text-success" : "text-danger")">
                                            <i class="fas @(p.Activo ? "fa-check-circle" : "fa-times-circle") me-1"></i>
                                            @(p.Activo ? "Activo" : "Inactivo")
                                        </span>
                                    </td>
                                    <td class="pe-4 text-end">
                                        <a asp-action="EditarProveedor" asp-route-id="@p.IdProveedor"
                                           class="btn btn-sm btn-outline-warning me-2" style="border-radius: 0;" title="Editar">
                                            <i class="fas fa-pen"></i>
                                        </a>
                                        <form method="post" asp-action="ToggleProveedor" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@p.IdProveedor" />
                                            <button type="submit"
                                                    class="btn btn-sm @(p.Activo ? "btn-outline-danger" : "btn-outline-light")"
                                                    style="border-radius: 0;"
                                                    title="@(p.Activo ? "Desactivar" : "Activar")">
                                                <i class="fas @(p.Activo ? "fa-ban" : "fa-check")"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-secondary p-5 text-center" style="font-style: italic;">
                                    No hay proveedores registrados. Crea el primero con el botón superior.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
