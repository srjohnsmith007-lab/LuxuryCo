@model List<LuxuryCo.Front.ViewModels.UsuarioViewModel>
@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="container-fluid py-5" style="background-color: #000; min-height: 100vh; color: #fff;">
    <div class="d-flex justify-content-between align-items-center px-4 pt-3">
        <div>
            <h1 class="display-5 fw-bold" style="font-family: 'Playfair Display', serif; letter-spacing: 2px;">USUARIOS</h1>
            <p class="text-secondary">Gestión y control de cuentas activas en la plataforma.</p>
        </div>
        <div class="text-end">
            <span class="badge border border-secondary text-secondary px-3 py-2" style="background-color: #111; font-weight: normal; letter-spacing: 1px;">
                <i class="fas fa-users me-2"></i> @(Model?.Count ?? 0) REGISTRADOS
            </span>
            <a asp-action="CrearUsuario" asp-controller="Admin" class="btn btn-outline-light ms-3 px-4 py-2" style="border-radius: 0; letter-spacing: 1px; font-weight: 500; font-size: 0.85rem;">
                <i class="fas fa-plus me-2"></i> NUEVO USUARIO
            </a>
        </div>
    </div>

    <!-- Pestañas de Navegación Admin -->
    <partial name="_AdminNav" />

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mx-4" role="alert" style="border-radius: 0; background-color: #1a3a1a; color: #fff; border: 1px solid #2e7d32;">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mx-4" role="alert" style="border-radius: 0; background-color: #3d1a1a; color: #fff; border: 1px solid #7d2e2e;">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card mx-4" style="background-color: #111; border: 1px solid #222; border-radius: 0;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0" style="vertical-align: middle;">
                    <thead style="background-color: #1a1a1a;">
                        <tr>
                            <th class="ps-4 py-3" style="width: 80px;">ID</th>
                            <th class="py-3">NOMBRE COMPLETO</th>
                            <th class="py-3">EMAIL</th>
                            <th class="py-3 text-center">ROL</th>
                            <th class="py-3 text-center">SEDE</th>
                            <th class="py-3 text-center">ESTADO</th>
                            <th class="py-3">REGISTRO</th>
                            <th class="pe-4 py-3 text-end">ACCIONES</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Count > 0)
                        {
                            @foreach (var u in Model)
                            {
                                var nombre = string.Join(" ", new[] { u.Nombre, u.Apellido }.Where(s => !string.IsNullOrEmpty(s)));
                                var fechaStr = u.FechaRegistro?.ToString("dd/MM/yyyy") ?? "-";

                                <tr id="user-@u.IdUsuario">
                                    <td class="ps-4 text-secondary">#@u.IdUsuario</td>
                                    <td class="fw-bold">@(string.IsNullOrEmpty(nombre) ? "Usuario Sin Nombre" : nombre)</td>
                                    <td class="text-secondary">@(u.Email ?? "-")</td>
                                    <td class="text-center">
                                        <span class="badge @(u.Rol == "ADMIN" ? "bg-light text-dark" : "bg-dark border border-secondary text-secondary")">@(u.Rol ?? "-")</span>
                                    </td>
                                    <td class="text-center text-secondary small">
                                        <i class="fas fa-store-alt me-1"></i> @(u.SedeNombre ?? "Global")
                                    </td>
                                    <td class="text-center">
                                        <span class="@(u.Activo ? "text-success" : "text-danger")">
                                            <i class="fas @(u.Activo ? "fa-check-circle" : "fa-times-circle") me-1"></i> @(u.Activo ? "Activo" : "Inactivo")
                                        </span>
                                    </td>
                                    <td class="text-secondary small">@fechaStr</td>
                                    <td class="pe-4 text-end">
                                        <a asp-action="EditarUsuario" asp-route-id="@u.IdUsuario" class="btn btn-sm btn-outline-warning me-2" style="border-radius: 0;" title="Editar">
                                            <i class="fas fa-pen"></i>
                                        </a>
                                        <form method="post" asp-action="ToggleUsuario" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@u.IdUsuario" />
                                            <input type="hidden" name="activar" value="@(u.Activo ? "false" : "true")" />
                                            <button type="submit" class="btn btn-sm @(u.Activo ? "btn-outline-danger" : "btn-outline-light")" style="border-radius: 0;" title="Cambiar Estado">
                                                @if(u.Activo)
                                                {
                                                    <i class="fas fa-ban"></i>
                                                }
                                                else
                                                {
                                                    <i class="fas fa-check"></i>
                                                }
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-secondary p-5 text-center" style="font-style: italic;">
                                    No hay usuarios registrados.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
