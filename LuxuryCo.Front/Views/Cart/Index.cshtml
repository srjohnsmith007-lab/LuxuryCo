@model LuxuryCo.Front.ViewModels.CarritoViewModel
@{
    ViewData["Title"] = "Tu Carrito";
}

<div class="container-fluid py-5" style="background-color: #000; min-height: 100vh; color: #fff;">
    <div class="container">
        <h1 class="display-5 fw-bold mb-5" style="font-family: 'Playfair Display', serif; letter-spacing: 2px; border-bottom: 1px solid #222; padding-bottom: 20px;">CARRITO DE COMPRAS</h1>

        @if (TempData["CartMessage"] != null)
        {
            <div class="alert alert-success bg-dark text-success border-success rounded-0 mb-4 shadow-sm">
                <i class="fas fa-check-circle me-2"></i> @TempData["CartMessage"]
            </div>
        }
        @if (TempData["CartError"] != null)
        {
            <div class="alert alert-danger bg-dark text-danger border-danger rounded-0 mb-4 shadow-sm">
                <i class="fas fa-exclamation-triangle me-2"></i> @TempData["CartError"]
            </div>
        }

        @if (Model != null && Model.Detalles.Any())
        {
            <div class="row g-5">
                <!-- Lista de Productos -->
                <div class="col-lg-8">
                    @foreach (var item in Model.Detalles)
                    {
                        <div class="d-flex align-items-center py-4 border-bottom border-zinc-800" style="border-color: #222 !important;">
                            <div class="flex-shrink-0" style="width: 120px; height: 150px; background: #111 url('@(string.IsNullOrEmpty(item.ImagenUrl) ? "https://via.placeholder.com/150" : item.ImagenUrl)') center/cover no-repeat;">
                            </div>
                            <div class="flex-grow-1 ms-4">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h5 class="fw-bold mb-1" style="letter-spacing: 1px;">@item.NombreProducto</h5>
                                        <p class="text-secondary small mb-1">Marca: @item.MarcaNombre</p>
                                        @if (!string.IsNullOrEmpty(item.Talla))
                                        {
                                            <p class="text-secondary small mb-1">Talla: <strong class="text-white">@item.Talla</strong></p>
                                        }
                                        <p class="text-secondary small mb-3">Ref: #@item.IdProducto</p>
                                    </div>
                                    <h5 class="fw-bold text-light">$@(string.Format("{0:N0}", item.PrecioUnitario))</h5>
                                </div>

                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <form asp-action="Update" method="post" class="d-flex align-items-center">
                                        <input type="hidden" name="id" value="@item.IdProducto" />
                                        <div class="input-group input-group-sm" style="width: 120px;">
                                            <button type="submit" name="quantity" value="@(item.Cantidad - 1)" class="btn btn-outline-secondary border-secondary text-white rounded-0">-</button>
                                            <input type="text" class="form-control bg-transparent border-secondary text-white text-center rounded-0 fw-bold" value="@item.Cantidad" readonly />
                                            <button type="submit" name="quantity" value="@(item.Cantidad + 1)" class="btn btn-outline-secondary border-secondary text-white rounded-0">+</button>
                                        </div>
                                    </form>

                                    <div class="d-flex align-items-center gap-4">
                                        <div class="fw-bold text-light" style="font-size: 1.1em;">Total: $@(string.Format("{0:N0}", item.Subtotal))</div>
                                        <form asp-action="Remove" method="post">
                                            <input type="hidden" name="id" value="@item.IdDetalleCarrito" />
                                            <button type="submit" class="btn btn-link text-secondary text-decoration-none small p-0 hover-danger">
                                                <i class="fas fa-trash-alt me-1"></i> ELIMINAR
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="mt-4">
                        <a asp-controller="Shop" asp-action="Category" class="text-secondary text-decoration-none small fw-bold" style="letter-spacing: 1px;">
                            <i class="fas fa-chevron-left me-2"></i> CONTINUAR COMPRANDO
                        </a>
                    </div>
                </div>

                <!-- Resumen de Pedido -->
                <div class="col-lg-4">
                    <div class="card bg-zinc-900 border-0 rounded-0 p-4 sticky-top" style="background-color: #0c0c0c; border: 1px solid #1a1a1a !important; top: 120px;">
                        <h4 class="fw-bold mb-4 text-white" style="font-family: 'Playfair Display', serif;">RESUMEN DE ORDEN</h4>
                        
                        <div class="d-flex justify-content-between mb-3 text-secondary">
                            <span>Artículos (@Model.TotalItems)</span>
                            <span>$@(string.Format("{0:N0}", Model.Total))</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3 text-secondary">
                            <span>Envío Estándar</span>
                            <span class="text-success small fw-bold">GRATIS</span>
                        </div>
                        
                        <hr style="border-color: #333;">
                        
                        <div class="d-flex justify-content-between mb-4 text-white">
                            <span class="h5 fw-bold">TOTAL FINAL</span>
                            <span class="h5 fw-bold" style="color: var(--gold, #d4af37);">$@(string.Format("{0:N0}", Model.Total))</span>
                        </div>

                        <a asp-controller="Checkout" asp-action="Index" class="btn btn-light w-100 py-3 fw-bold rounded-0 text-dark mb-3 text-decoration-none text-center" style="letter-spacing: 2px;">
                            PAGAR AHORA <i class="fas fa-lock ms-2"></i>
                        </a>

                        <div class="mt-2 text-center text-secondary small">
                            <i class="fas fa-shield-alt me-1"></i> Transacción segura y cifrada
                        </div>

                        <div class="mt-4 text-center">
                            <img src="https://luxuryaccesories.co/cdn/shop/files/metodos-pago.png" class="img-fluid opacity-50 hover-opacity-100 transition-all" style="max-height: 25px; filter: grayscale(100%); transition: all 0.3s ease;" alt="Pagos">
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-shopping-bag fa-4x text-secondary mb-4 opacity-25" style="color: #333 !important;"></i>
                <h3 class="fw-bold mb-3 text-white" style="font-family: 'Playfair Display', serif;">TU CARRITO ESTÁ VACÍO</h3>
                <p class="text-secondary mb-5">Parece que aún no has añadido ningún tesoro exclusivo a tu colección.</p>
                <a asp-controller="Shop" asp-action="Category" class="btn btn-outline-light px-5 py-3 rounded-0 fw-bold" style="letter-spacing: 2px; border-width: 2px;">
                    EXPLORAR COLECCIÓN
                </a>
            </div>
        }
    </div>
</div>

