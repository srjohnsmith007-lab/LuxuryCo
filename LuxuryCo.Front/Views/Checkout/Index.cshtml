@model LuxuryCo.Front.ViewModels.CheckoutRequestViewModel
@{
    ViewData["Title"] = "Paso Final - Checkout";
    var cart = ViewBag.CartSummary as LuxuryCo.Front.ViewModels.CarritoViewModel;
    decimal envio = cart != null && cart.Total > 500000 ? 0 : 25000;
    decimal iva = cart != null ? cart.Total * 0.19m : 0;
    decimal totalFinal = cart != null ? cart.Total + iva + envio : 0;
}

<div class="container-fluid py-5" style="background-color: #000; min-height: 100vh; color: #fff;">
    <div class="container">
        <div class="text-center mb-5">
            <h1 class="display-6 fw-bold" style="font-family: 'Playfair Display', serif; letter-spacing: 2px;">FINALIZAR COMPRA</h1>
            <p class="text-secondary">Información encriptada mediante protocolo SSL de 256 bits.</p>
        </div>

        @if (TempData["CheckoutError"] != null)
        {
            <div class="alert alert-danger bg-dark text-danger border-danger rounded-0 mb-4 shadow-sm">
                <i class="fas fa-exclamation-triangle me-2"></i> @TempData["CheckoutError"]
            </div>
        }

        <div class="row g-5">
            <!-- Checkout Form -->
            <div class="col-lg-7">
                <form asp-action="PlaceOrder" method="post" id="checkoutForm">
                    <!-- IDEMPOTENCY TOKEN MOCK -->
                    <input type="hidden" asp-for="IdempotencyKey" id="IdempotencyKey" />
                    <input type="hidden" asp-for="CardToken" value="tok_mock_2026_vip" />

                    <!-- PASO 1: ENVÍO -->
                    <h4 class="fw-bold mb-4" style="border-bottom: 1px solid #333; padding-bottom: 10px; color: var(--gold, #d4af37);">1. Detalles de Envío</h4>
                    
                    <div class="row g-3 mb-5">
                        <div class="col-12">
                            <label class="form-label text-secondary small">Dirección de Entrega</label>
                            <input asp-for="DireccionLinea1" class="form-control bg-dark border-secondary text-white rounded-0 py-3" placeholder="Ej. Calle 123 #45-67" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary small">Ciudad</label>
                            <input asp-for="Ciudad" class="form-control bg-dark border-secondary text-white rounded-0 py-3" placeholder="Bogotá, Medellín..." required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary small">Código Postal</label>
                            <input asp-for="CodigoPostal" class="form-control bg-dark border-secondary text-white rounded-0 py-3" placeholder="Postcode" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary small">Teléfono de Contacto</label>
                            <input asp-for="Telefono" class="form-control bg-dark border-secondary text-white rounded-0 py-3" placeholder="(+57) 300 000 0000" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary small">Instrucciones Adicionales</label>
                            <input asp-for="Referencias" class="form-control bg-dark border-secondary text-white rounded-0 py-3" placeholder="Ej. Dejar en recepción" />
                        </div>
                    </div>

                    <!-- PASO 2: PAGO (MOCK) -->
                    <h4 class="fw-bold mb-4" style="border-bottom: 1px solid #333; padding-bottom: 10px; color: var(--gold, #d4af37);">2. Método de Pago</h4>
                    <div class="p-4 mb-4" style="background-color: #0a0a0a; border: 1px solid #222;">
                        <div class="d-flex justify-content-between mb-4">
                            <span class="text-white fw-bold"><i class="fas fa-credit-card me-2"></i> Tarjeta de Crédito</span>
                            <div class="text-secondary text-end" style="font-size: 0.8rem;">
                                Entorno de Prueba / Mock
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label text-secondary small">Número de Tarjeta (Ficticio)</label>
                            <input type="text" class="form-control bg-dark border-secondary text-white rounded-0 py-2" value="•••• •••• •••• 4242" disabled />
                        </div>
                        <div class="row">
                            <div class="col-6">
                                <label class="form-label text-secondary small">Vencimiento</label>
                                <input type="text" class="form-control bg-dark border-secondary text-white rounded-0 py-2" value="12/28" disabled />
                            </div>
                            <div class="col-6">
                                <label class="form-label text-secondary small">CVC</label>
                                <input type="text" class="form-control bg-dark border-secondary text-white rounded-0 py-2" value="•••" disabled />
                            </div>
                        </div>
                    </div>

                    <button type="submit" id="btnPagar" class="btn btn-light w-100 py-3 fw-bold rounded-0 text-dark mt-3" style="letter-spacing: 2px;">
                        AUTORIZAR PAGO Y COMPLETAR COMPRA
                    </button>
                    <div id="loadingSpinner" class="text-center mt-3 d-none">
                        <div class="spinner-border text-light" role="status">
                            <span class="visually-hidden">Procesando...</span>
                        </div>
                        <p class="text-secondary small mt-2">Contactando banco de emisión...</p>
                    </div>
                </form>
            </div>

            <!-- Resumen Right Sidebar -->
            <div class="col-lg-5">
                <div class="card border-0 rounded-0 p-4 sticky-top" style="background-color: #0c0c0c; border: 1px solid #1a1a1a !important; top: 100px;">
                    <h4 class="fw-bold mb-4 text-white" style="font-family: 'Playfair Display', serif;">TU ORDEN</h4>
                    
                    @if (cart != null)
                    {
                        <div class="mb-4" style="max-height: 250px; overflow-y: auto;">
                            @foreach(var item in cart.Detalles)
                            {
                                <div class="d-flex align-items-center mb-3">
                                    <div style="width: 50px; height: 60px; background: #222 url('@(string.IsNullOrEmpty(item.ImagenUrl) ? "" : item.ImagenUrl)') center/cover;"></div>
                                    <div class="ms-3 flex-grow-1">
                                        <div class="text-white small fw-bold">@item.NombreProducto</div>
                                        <div class="text-secondary" style="font-size: 0.75rem;">Cant: @item.Cantidad x $@string.Format("{0:N0}", item.PrecioUnitario)</div>
                                    </div>
                                </div>
                            }
                        </div>
                        
                        <hr style="border-color: #333;">
                        
                        <div class="d-flex justify-content-between mb-2 text-secondary small">
                            <span>Subtotal Neto</span>
                            <span>$@(string.Format("{0:N0}", cart.Total))</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2 text-secondary small">
                            <span>IVA (19%)</span>
                            <span>$@(string.Format("{0:N0}", iva))</span>
                        </div>
                        <div class="d-flex justify-content-between mb-4 text-secondary small">
                            <span>Envío Domicilio Seguro</span>
                            <span class="@(envio == 0 ? "text-success fw-bold" : "")">@(envio == 0 ? "GRATIS" : "$" + string.Format("{0:N0}", envio))</span>
                        </div>
                        
                        <div class="d-flex justify-content-between text-white border-top pt-3 mt-2" style="border-color: #333 !important;">
                            <span class="h5 fw-bold">TOTAL GASTO</span>
                            <span class="h5 fw-bold" style="color: var(--gold, #d4af37);">$@(string.Format("{0:N0}", totalFinal))</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Set un UUID para prevenir recargas o doble clic si no existiera
        if (!document.getElementById("IdempotencyKey").value) {
            document.getElementById("IdempotencyKey").value = crypto.randomUUID();
        }

        document.getElementById("checkoutForm").addEventListener("submit", function(e) {
            document.getElementById("btnPagar").classList.add("d-none");
            document.getElementById("loadingSpinner").classList.remove("d-none");
        });
    </script>
}
