@{
    ViewData["Title"] = "Inicio";
}

<!-- Hero Section -->
<div class="hero-section position-relative" style="height: calc(100vh - 80px); background-image: url('https://images.unsplash.com/photo-1490481651871-ab68de25d43d?q=80&w=2670&auto=format&fit=crop'); background-size: cover; background-position: center top;">
    <!-- Subtle Gradient Overlay for Text Readability -->
    <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: linear-gradient(to bottom, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.6) 100%);"></div>
    
    <div class="position-absolute w-100 h-100 d-flex flex-column align-items-center justify-content-center text-center px-3" style="z-index: 10;">
        <h1 class="text-white mb-3" style="font-family: 'Playfair Display', serif; font-size: 4rem; letter-spacing: 4px; text-transform: uppercase;">Nueva Colección</h1>
        <p class="text-white-50 mb-5" style="letter-spacing: 2px; text-transform: uppercase; font-size: 0.9rem; max-width: 600px;">Descubre la elegancia redefinida. Piezas exclusivas diseñadas para inspirar y cautivar.</p>
        <a href="#" class="btn btn-gold" style="width: auto; padding: 1rem 3rem;">Explorar Ahora</a>
    </div>
</div>

<!-- Featured Categories Section -->
<div class="container-fluid py-5" style="background-color: var(--color-black);">
    <div class="row g-1">
        <!-- Category 1 -->
        <div class="col-md-4 position-relative overflow-hidden group">
            <div style="height: 600px; background-image: url('https://images.unsplash.com/photo-1549439602-43ebca2327af?q=80&w=2670&auto=format&fit=crop'); background-size: cover; background-position: center; transition: transform 0.7s;" class="hover-zoom"></div>
            <div class="position-absolute bottom-0 start-0 w-100 p-4 text-center" style="background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);">
                <h3 class="text-white mb-1" style="font-family: 'Playfair Display', serif; letter-spacing: 2px;">Mujer</h3>
                <a asp-controller="Shop" asp-action="Category" asp-route-id="Mujer" class="text-white text-decoration-none" style="font-size: 0.8rem; letter-spacing: 1px; border-bottom: 1px solid var(--color-gold); padding-bottom: 2px;">DESCUBRIR</a>
            </div>
        </div>
        
        <!-- Category 2 -->
        <div class="col-md-4 position-relative overflow-hidden group">
            <div style="height: 600px; background-image: url('https://images.unsplash.com/photo-1516257984-b1b4d707412e?q=80&w=2574&auto=format&fit=crop'); background-size: cover; background-position: center; transition: transform 0.7s;" class="hover-zoom"></div>
            <div class="position-absolute bottom-0 start-0 w-100 p-4 text-center" style="background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);">
                <h3 class="text-white mb-1" style="font-family: 'Playfair Display', serif; letter-spacing: 2px;">Hombre</h3>
                <a asp-controller="Shop" asp-action="Category" asp-route-id="Hombre" class="text-white text-decoration-none" style="font-size: 0.8rem; letter-spacing: 1px; border-bottom: 1px solid var(--color-gold); padding-bottom: 2px;">DESCUBRIR</a>
            </div>
        </div>
        
        <!-- Category 3 -->
        <div class="col-md-4 position-relative overflow-hidden group">
            <div style="height: 600px; background-image: url('https://images.unsplash.com/photo-1560343090-f0409e92791a?q=80&w=2648&auto=format&fit=crop'); background-size: cover; background-position: center; transition: transform 0.7s;" class="hover-zoom"></div>
            <div class="position-absolute bottom-0 start-0 w-100 p-4 text-center" style="background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);">
                <h3 class="text-white mb-1" style="font-family: 'Playfair Display', serif; letter-spacing: 2px;">Accesorios</h3>
                <a asp-controller="Shop" asp-action="Category" asp-route-id="Accesorios" class="text-white text-decoration-none" style="font-size: 0.8rem; letter-spacing: 1px; border-bottom: 1px solid var(--color-gold); padding-bottom: 2px;">DESCUBRIR</a>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-zoom:hover {
        transform: scale(1.05);
    }
</style>
