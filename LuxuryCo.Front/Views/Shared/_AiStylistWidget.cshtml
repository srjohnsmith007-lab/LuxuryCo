<div id="ai-stylist-widget" class="floating-chat-container">
    <!-- Botón Flotante -->
    <button id="ai-stylist-toggle" class="btn-floating-chat shadow-lg">
        <i class="fas fa-gem me-1"></i> Asesor de Estilo
    </button>

    <!-- Ventana del Chat -->
    <div id="ai-stylist-box" class="chat-window shadow-lg d-none">
        <div class="chat-header d-flex justify-content-between align-items-center">
            <div>
                <i class="fas fa-gem text-gold me-2"></i>
                <span class="fw-bold">LuxuryCo Stylist</span>
            </div>
            <div>
                <button class="btn btn-sm text-white px-2" onclick="clearStylistChat()" title="Limpiar conversación">
                    <i class="fas fa-trash-alt"></i>
                </button>
                <button class="btn btn-sm text-white px-2" id="ai-stylist-close">
                    <i class="fas fa-times"></i>
                </button>
            </div>
        </div>
        
        <div class="chat-body" id="stylist-messages">
            <!-- El saludo se genera dinámicamente en JS según la página -->
        </div>
        
        <div id="stylist-typing" class="typing-indicator d-none p-2 mb-2">
            <div class="typing-line"></div>
        </div>

        <form id="stylist-form" class="chat-footer d-flex">
            <input type="text" id="stylist-input" class="form-control" placeholder="Ej: Camisas de lino oscuro..." autocomplete="off" required>
            <button type="submit" class="btn btn-send">
                <i class="fas fa-paper-plane"></i>
            </button>
        </form>
    </div>
</div>

<style>
    :root {
        --chat-primary: #000000;
        --chat-secondary: #1a1a1a;
        --chat-accent: #C9A84C;
        --chat-text: #e0e0e0;
    }

    .floating-chat-container {
        position: fixed;
        bottom: 30px;
        right: 30px;
        z-index: 9999;
        font-family: 'Inter', sans-serif;
    }

    .btn-floating-chat {
        background-color: var(--chat-primary);
        color: var(--chat-accent);
        border: 1px solid var(--chat-accent);
        border-radius: 30px;
        padding: 12px 24px;
        font-weight: bold;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(201, 168, 76, 0.3) !important;
    }

    .btn-floating-chat:hover {
        background-color: var(--chat-accent);
        color: var(--chat-primary);
        transform: translateY(-2px);
    }

    .chat-window {
        width: 360px;
        height: 500px;
        /* The Kinetic Monolith: Glassmorphism */
        background-color: rgba(5, 5, 5, 0.75);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(201, 168, 76, 0.2);
        box-shadow: 0 10px 40px rgba(0,0,0,0.9), inset 0 0 0 1px rgba(255,255,255,0.05) !important;
        border-radius: 12px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        position: absolute;
        bottom: 60px;
        right: 0;
        transform-origin: bottom right;
        animation: scaleIn 0.3s cubic-bezier(0.19, 1, 0.22, 1);
    }

    @@keyframes scaleIn {
        from { transform: scale(0.5); opacity: 0; }
        to { transform: scale(1); opacity: 1; }
    }

    .chat-header {
        background-color: rgba(15, 15, 15, 0.85);
        padding: 15px;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        color: white;
    }

    .text-gold {
        color: var(--chat-accent);
    }

    .chat-body {
        flex: 1;
        padding: 15px;
        overflow-y: auto;
        background-color: transparent;
    }

    /* Scrollbar */
    .chat-body::-webkit-scrollbar { width: 4px; }
    .chat-body::-webkit-scrollbar-track { background: transparent; }
    .chat-body::-webkit-scrollbar-thumb { background-color: #333; border-radius: 10px; }

    .msg-bubble {
        max-width: 85%;
        padding: 10px 14px;
        border-radius: 8px;
        font-size: 0.9rem;
        line-height: 1.4;
        word-wrap: break-word;
    }

    .ai-bubble {
        background-color: var(--chat-secondary);
        color: var(--chat-text);
        border-left: 2px solid var(--chat-accent);
        margin-right: auto;
        border-bottom-left-radius: 0;
    }

    .user-bubble {
        background-color: #222;
        color: white;
        margin-left: auto;
        border-bottom-right-radius: 0;
    }

    /* Línea de Carga (Typing Indicator) */
    .typing-line {
        width: 40px;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--chat-accent), transparent);
        animation: pulseLine 1.5s ease-in-out infinite;
        margin-left: 10px;
    }
    @@keyframes pulseLine {
        0% { opacity: 0.3; transform: scaleX(0.5); }
        50% { opacity: 1; transform: scaleX(1); box-shadow: 0 0 10px rgba(201,168,76,0.6); }
        100% { opacity: 0.3; transform: scaleX(0.5); }
    }

    .chat-footer {
        padding: 10px;
        background-color: rgba(15, 15, 15, 0.85);
        border-top: 1px solid rgba(255,255,255,0.05);
    }

    .chat-footer input {
        background-color: #111;
        border: 1px solid #444;
        color: white;
        border-radius: 20px;
        font-size: 0.9rem;
    }

    .chat-footer input:focus {
        background-color: #000;
        color: white;
        border-color: var(--chat-accent);
        box-shadow: none;
    }

    .btn-send {
        background-color: transparent;
        color: var(--chat-accent);
        border: none;
        padding: 0 15px;
        font-size: 1.2rem;
    }

    .btn-send:hover {
        color: white;
    }

    /* Typing Animation */
    .typing-indicator {
        padding: 10px 15px;
        background-color: var(--chat-secondary);
        display: inline-block;
        border-radius: 15px;
        margin-bottom: 15px;
        margin-left: 15px;
    }
    .dot {
        display: inline-block;
        width: 6px;
        height: 6px;
        background-color: var(--chat-accent);
        border-radius: 50%;
        margin: 0 2px;
        animation: bounce 1.3s linear infinite;
    }
    .dot:nth-child(2) { animation-delay: -1.1s; }
    .dot:nth-child(3) { animation-delay: -0.9s; }

    @@keyframes bounce {
        0%, 60%, 100% { transform: translateY(0); }
        30% { transform: translateY(-4px); }
    }
    /* ── Product Cards ── */
    .product-cards-row {
        display: flex;
        gap: 8px;
        padding: 4px 0 8px;
        flex-wrap: wrap;
    }

    .product-card-mini {
        display: flex;
        flex-direction: column;
        width: 140px;
        background: #111;
        border: 1px solid #2a2a2a;
        border-radius: 8px;
        overflow: hidden;
        text-decoration: none;
        transition: border-color 0.2s, transform 0.2s;
        flex-shrink: 0;
    }

    .product-card-mini:hover {
        border-color: var(--chat-accent);
        transform: translateY(-2px);
    }

    .product-card-mini img {
        width: 100%;
        height: 100px;
        object-fit: cover;
        background: #1a1a1a;
    }

    .pc-body {
        padding: 8px;
    }

    .pc-name {
        color: #e0e0e0;
        font-size: 0.75rem;
        font-weight: 600;
        margin: 0 0 2px;
        line-height: 1.3;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .pc-section {
        color: #666;
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin: 0 0 4px;
    }

    .pc-price {
        color: var(--chat-accent);
        font-size: 0.78rem;
        font-weight: 700;
        margin: 0 0 6px;
    }

    .pc-btn {
        display: block;
        font-size: 0.65rem;
        color: var(--chat-accent);
        letter-spacing: 0.5px;
        text-transform: uppercase;
        border-top: 1px solid #222;
        padding-top: 5px;
    }
</style>

<script>
    // Variables globales
    const chatToggle = document.getElementById('ai-stylist-toggle');
    const chatBox = document.getElementById('ai-stylist-box');
    const chatClose = document.getElementById('ai-stylist-close');
    const stylistForm = document.getElementById('stylist-form');
    const stylistInput = document.getElementById('stylist-input');
    const stylistMessages = document.getElementById('stylist-messages');
    const stylistTyping = document.getElementById('stylist-typing');

    // Generar o recuperar Session ID para la Base de Datos
    let currentSessionId = localStorage.getItem('luxuryco_ai_session_id');
    if (!currentSessionId) {
        currentSessionId = 'session_' + Math.random().toString(36).substr(2, 9);
        localStorage.setItem('luxuryco_ai_session_id', currentSessionId);
    }

    // ── Estado del chat ────────────────────────────────────────────
    let chatGreetingShown = false;

    function buildSmartGreeting() {
        const path = window.location.pathname.toLowerCase();
        const isProductDetail = path.includes('/catalogo/detalle');
        const isCatalog = path.includes('/catalogo') && !isProductDetail;
        const isCart = path.includes('/carrito');
        const isCheckout = path.includes('/checkout');

        if (isProductDetail) {
            const productTitle = document.querySelector('h1')?.innerText?.trim() || 'este producto';
            return `¡Hola! 👋 Veo que estás mirando <strong>${productTitle}</strong>.<br><br>¿Tienes alguna duda sobre <strong>tallas, envíos o devoluciones</strong>? Estoy aquí para ayudarte. 😊`;
        }
        if (isCatalog) {
            return '¡Hola! Bienvenido a nuestro catálogo. 🛍️<br>¿Buscas algo para una ocasión especial o quieres explorar las últimas tendencias de LuxuryCo?';
        }
        if (isCart) {
            return '¡Hola! Veo que tienes artículos en tu carrito. 🛒<br>¿Puedo ayudarte con algo antes de finalizar tu compra? También puedo sugerirte looks completos.';
        }
        if (isCheckout) {
            return '¡Ya casi es tuyo! 🎉<br>¿Tienes alguna duda sobre el proceso de pago o los tiempos de entrega?';
        }
        return '¡Hola! Soy tu asesor de estilo personal de LuxuryCo. ✨<br>¿Buscas algo para una ocasión especial o quieres explorar nuevas tendencias?';
    }

    document.addEventListener("DOMContentLoaded", () => {
        // Toggle: abrir/cerrar con saludo inmediato en la primera apertura
        chatToggle.addEventListener('click', () => {
            chatBox.classList.toggle('d-none');
            if (!chatBox.classList.contains('d-none')) {
                if (!chatGreetingShown) {
                    chatGreetingShown = true;
                    addMessageToUI(buildSmartGreeting(), 'ai');
                }
                stylistInput.focus();
                scrollToBottom();
            }
        });

        chatClose.addEventListener('click', () => {
            chatBox.classList.add('d-none');
        });

        // Enviar mensaje
        stylistForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const text = stylistInput.value.trim();
            if (!text) return;

            // Limpiar input y agregar mensaje de usuario
            stylistInput.value = '';
            addMessageToUI(text, 'user');
            
            // Mostrar "escribiendo..."
            stylistTyping.classList.remove('d-none');
            scrollToBottom();

            try {
                // Ahora enviamos el sessionId en lugar de todo el historial
                const response = await fetch('/Home/SendStylistMessage', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        message: text,
                        sessionId: currentSessionId
                    })
                });

                let data;
                const rawText = await response.text();
                try { data = JSON.parse(rawText); }
                catch {
                    addMessageToUI("⚠️ Error de formato en la respuesta del servidor.", 'ai');
                    return;
                }

                if (response.ok) {
                    addMessageToUI(data.reply, 'ai');
                    // Render product cards if any
                    if (data.cards && data.cards.length > 0) {
                        renderProductCards(data.cards);
                    }
                } else {
                    addMessageToUI("⚠️ " + (data.message || "Error al conectar con el servidor."), 'ai');
                }
            } catch (error) {
                addMessageToUI("⚠️ Error de conexión.", 'ai');
            } finally {
                stylistTyping.classList.add('d-none');
                scrollToBottom();
            }
        });
    });

    function addMessageToUI(text, sender) {
        const div = document.createElement('div');
        div.className = `msg-bubble ${sender}-bubble mb-3`;
        
        let formattedText = text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
        formattedText = formattedText.replace(/\n/g, '<br>');
        
        div.innerHTML = formattedText;
        stylistMessages.appendChild(div);
    }

    function renderProductCards(cards) {
        const container = document.createElement('div');
        container.className = 'product-cards-row';

        cards.forEach(card => {
            const formatted = new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(card.precio);
            const cardEl = document.createElement('a');
            cardEl.href = card.url;
            cardEl.className = 'product-card-mini';
            cardEl.innerHTML = `
                <img src="${card.imagen}" alt="${card.nombre}" onerror="this.src='/img/placeholder.png'">
                <div class="pc-body">
                    <p class="pc-name">${card.nombre}</p>
                    <p class="pc-section">${card.seccion}</p>
                    <p class="pc-price">${formatted}</p>
                    <span class="pc-btn">Ver producto →</span>
                </div>
            `;
            container.appendChild(cardEl);
        });

        stylistMessages.appendChild(container);
    }

    function clearStylistChat() {
        currentSessionId = 'session_' + Math.random().toString(36).substr(2, 9);
        localStorage.setItem('luxuryco_ai_session_id', currentSessionId);
        chatGreetingShown = false;
        stylistMessages.innerHTML = '';
        addMessageToUI(buildSmartGreeting(), 'ai');
        chatGreetingShown = true;
    }

    function scrollToBottom() {
        stylistMessages.scrollTop = stylistMessages.scrollHeight;
    }

    // ── Auto-Open & Proactive Trigger (Paso 2.4) ──────────────────────────────
    (function initProactiveTrigger() {
        const isClosed = sessionStorage.getItem('luxuryco_chat_closed');
        const hasOpened = sessionStorage.getItem('luxuryco_chat_opened');

        // Función para abrir suavemente el chat
        function autoOpenChat() {
            if (!chatBox.classList.contains('d-none')) return;
            sessionStorage.setItem('luxuryco_chat_opened', '1');
            chatBox.classList.remove('d-none');
            
            if (!chatGreetingShown) {
                chatGreetingShown = true;
                addMessageToUI(buildSmartGreeting(), 'ai');
            }
            scrollToBottom();
        }

        // 1. Si el usuario nunca lo ha cerrado, abrir automáticamente al entrar a la página
        //    Ponemos un pequeño retraso (1.5s) para que la página cargue primero y se vea la animación
        if (!isClosed && !hasOpened) {
            setTimeout(autoOpenChat, 1500);
        }

        // 2. Si el usuario lo cierra, recordar su preferencia en esta sesión
        chatClose.addEventListener('click', () => {
            sessionStorage.setItem('luxuryco_chat_closed', '1');
        });

        // 3. Mantener el gatillo de 45 segundos solo si está en un producto y lo había cerrado
        const isProductPage = window.location.pathname.toLowerCase().includes('/catalogo/detalle');
        if (isProductPage && !sessionStorage.getItem('luxuryco_proactive_fired')) {
            const proactiveTimer = setTimeout(() => {
                sessionStorage.setItem('luxuryco_proactive_fired', '1');
                autoOpenChat();
            }, 45000);

            chatToggle.addEventListener('click', () => clearTimeout(proactiveTimer), { once: true });
        }
    })();
</script>
