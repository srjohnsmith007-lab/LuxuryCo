@using LuxuryCo.Front.ViewModels
@model IEnumerable<ProductoViewModel>

@{
    ViewData["Title"] = ViewData["CategoryName"];
}

<style>
    /* Category Header Styles */
    .category-header {
        text-align: center;
        padding: 40px 0 20px 0;
        border-bottom: 1px solid #eaeaea;
        margin-bottom: 30px;
    }
    .category-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.5rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-bottom: 20px;
        font-weight: 600;
        color: #000;
    }
    .brand-tabs {
        display: flex;
        justify-content: center;
        gap: 30px;
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .brand-tabs li {
        font-size: 0.9rem;
        font-weight: 500;
        color: #777;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        position: relative;
    }
    .brand-tabs li.active {
        color: #000;
        font-weight: 600;
    }
    .brand-tabs li.active::after {
        content: '';
        position: absolute;
        bottom: -5px;
        left: 0;
        width: 100%;
        height: 2px;
        background-color: #000;
    }

    /* Filters and Sorting (Mockup) */
    .filters-bar {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        margin-bottom: 30px;
        padding-right: 15px;
    }
    .sort-dropdown {
        padding: 8px 15px;
        border: 1px solid #ddd;
        border-radius: 4px;
        font-size: 0.85rem;
        color: #555;
        background-color: transparent;
        cursor: pointer;
        outline: none;
    }

    /* Product Grid Styles */
    .product-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 50px;
    }
    @@media (max-width: 1200px) {
        .product-grid { grid-template-columns: repeat(3, 1fr); }
    }
    @@media (max-width: 992px) {
        .product-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @@media (max-width: 576px) {
        .product-grid { grid-template-columns: 1fr; }
    }

    .product-card {
        text-align: left;
        display: flex;
        flex-direction: column;
        border: 1px solid transparent;
        transition: border 0.3s ease;
        position: relative;
    }
    .product-card:hover {
        border: 1px solid #f0f0f0;
    }
    
    .product-image-container {
        width: 100%;
        aspect-ratio: 3/4;
        background-color: #f7f7f7;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 15px;
        position: relative;
        overflow: hidden;
    }
    .product-image {
        max-width: 80%;
        max-height: 80%;
        object-fit: contain;
        transition: transform 0.5s ease;
    }
    .product-card:hover .product-image {
        transform: scale(1.05);
    }
    
    /* Hover Actions (Añadir a lista / Vista Rápida) */
    .product-actions {
        position: absolute;
        bottom: -50px;
        left: 0;
        width: 100%;
        background: #fff;
        display: flex;
        flex-direction: column;
        transition: bottom 0.3s ease;
        opacity: 0;
        box-shadow: 0 -5px 10px rgba(0,0,0,0.05);
    }
    .product-card:hover .product-actions {
        bottom: 0;
        opacity: 1;
    }
    .btn-action {
        background: none;
        border: none;
        border-top: 1px solid #eaeaea;
        padding: 10px;
        font-size: 0.8rem;
        color: #000;
        text-transform: uppercase;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }
    .btn-action:hover {
        background-color: #f9f9f9;
        color: var(--color-gold);
    }

    /* Badges */
    .badge-discount {
        position: absolute;
        left: -15px;
        top: 20px;
        background: #fff;
        padding: 10px 5px;
        writing-mode: vertical-rl;
        transform: rotate(180deg);
        font-weight: bold;
        font-size: 0.8rem;
        box-shadow: 2px 0 5px rgba(0,0,0,0.1);
        z-index: 2;
    }
    .badge-new {
        position: absolute;
        top: 10px;
        right: 10px;
        background: #000;
        color: #fff;
        padding: 4px 10px;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* Text info */
    .product-brand {
        font-size: 0.75rem;
        color: #999;
        text-transform: uppercase;
        margin-bottom: 5px;
        letter-spacing: 1px;
    }
    .product-name {
        font-size: 0.85rem;
        font-weight: 600;
        color: #000;
        text-transform: uppercase;
        margin-bottom: 8px;
        text-decoration: none;
        line-height: 1.4;
    }
    .product-name:hover {
        color: var(--color-gold);
        text-decoration: underline;
    }
    .product-price {
        font-size: 0.95rem;
        font-weight: 600;
        color: #000;
    }
</style>

<div class="container-fluid py-5" style="background-color: #000; min-height: calc(100vh - 78px); color: #fff;">
    <div class="category-header pb-4" style="border-bottom: 1px solid #222;">
        <h1 class="category-title text-white" style="font-family: 'Playfair Display', serif; letter-spacing: 2px;">@ViewData["CategoryName"]</h1>
    </div>

    <div class="container pb-5 mt-4">
        <div class="filters-bar text-secondary">
            <span class="mr-3" style="font-size: 0.85rem; text-transform: uppercase; font-weight: 500;">Ordenar por</span>
            <select class="sort-dropdown bg-dark text-white" style="border-color: #333;">
                <option>Fecha: recientes primero</option>
                <option>Precio: menor a mayor</option>
                <option>Precio: mayor a menor</option>
            </select>
        </div>

        @if (TempData["CartMessage"] != null)
        {
            <div class="alert alert-success bg-dark text-success border-success rounded-0 mb-4 shadow-sm" style="position: fixed; top: 100px; right: 20px; z-index: 1000;">
                <i class="fas fa-check-circle me-2"></i> @TempData["CartMessage"]
            </div>
        }
        @if (TempData["CartError"] != null)
        {
            <div class="alert alert-danger bg-dark text-danger border-danger rounded-0 mb-4 shadow-sm" style="position: fixed; top: 100px; right: 20px; z-index: 1000;">
                <i class="fas fa-exclamation-triangle me-2"></i> @TempData["CartError"]
            </div>
        }

        @if (Model != null && Model.Any())
        {
            <div class="product-grid">
                @foreach (var prod in Model)
                {
                    <div class="product-card" style="border-color: #111;">
                        <div class="product-image-container" style="background-color: #0c0c0c;">
                            <!-- Representativa / Principal -->
                            @{
                                var imgUrl = prod.ImagenPrincipalUrl != null ? prod.ImagenPrincipalUrl.ToString() : "https://via.placeholder.com/300x400.png?text=Prenda";
                            }
                            <a href="/Shop/Product/@prod.IdProducto" style="display: flex; width: 100%; height: 100%; justify-content: center; align-items: center; text-decoration: none;">
                                <img src="@imgUrl" class="product-image" alt="@prod.Nombre" style="width: 100%; height: 100%; object-fit: contain; padding: 10px;" />
                            </a>

                            <div class="product-actions" style="background: rgba(10,10,10,0.9); border-top: 1px solid var(--gold, #d4af37);">
                                <form asp-controller="Cart" asp-action="Add" method="post" style="width: 100%; margin: 0;">
                                    <input type="hidden" name="productId" value="@prod.IdProducto" />
                                    <input type="hidden" name="quantity" value="1" />
                                    <button type="submit" class="btn-action w-100 text-white" style="border: none; background: transparent; padding: 15px;">
                                        <i class="fas fa-shopping-bag"></i> AÑADIR AL CARRITO
                                    </button>
                                </form>
                            </div>
                        </div>
                        
                        <div class="product-brand" style="color: #777;">@(prod.MarcaNombre ?? "LuxuryCo MKS")</div>
                        <a href="/Shop/Product/@prod.IdProducto" class="product-name text-white">@prod.Nombre</a>
                        <div class="product-price text-white" style="color: var(--gold, #d4af37) !important;">$@(String.Format("{0:N2}", prod.Precio))</div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="alert text-center mt-5" style="border: 1px solid #222; color: #999; background-color: #0c0c0c; padding: 40px; font-family: 'Playfair Display', serif; letter-spacing: 1px;">
                <i class="fas fa-gem fa-2x mb-3" style="color: var(--color-gold, #d4af37);"></i>
                <h3 style="font-size: 1.5rem; color: #fff; text-transform: uppercase;">Próximamente</h3>
                <p style="font-size: 0.95rem; text-transform: uppercase;">No se han subido productos en esta categoría. Vuelve pronto para descubrir nuestras nuevas colecciones exclusivas.</p>
            </div>
        }
    </div>
</div>
